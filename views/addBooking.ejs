<%- include('layout/header') %>
<div class="container">
    <div class="row">
        <div class="col-lg-6 mx-auto mt-4">
            <div class="card shadow">
                <div class="card-header bg-primary">
                    <h5 class="text-light">Ajouter une nouvelle réservation</h5>
                </div>
                <div class="card-body p-4">
                    <form action="/api/bookings/" method="POST" id="add-booking-form">
                        <div class="mb-3">
                            <label for="user">Utilisateur</label>
                            <input type="text" name="user" id="user" class="form-control form-control-lg" placeholder="Entrez le ID de l'utilisateur" required/>
                        </div>
                        <div class="mb-3">
                            <label for="room">Salle de Réunion</label>
                            <input type="text-" name="room" id="room" class="form-control form-control-lg" placeholder="Entrez le  Id de room" required/>
                        </div>
                        <div class="mb-3">
                            <label for="startTime">Date de début</label>
                            <input type="datetime-local" name="startTime" id="startTime" class="form-control form-control-lg" required/>
                        </div>
                        <div class="mb-3">
                            <label for="endTime">Date de fin</label>
                            <input type="datetime-local" name="endTime" id="endTime" class="form-control form-control-lg" required/>
                        </div>
                        <div class="mb-3">
                            <input type="submit" name="submit" value="Ajouter une réservation" class="btn btn-primary btn-lg" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('layout/footer') %>
