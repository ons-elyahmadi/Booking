<%- include('layout/header') %>
<div class="container">
    <div class="row my-4">
        <div class="col-lg-12" >
            <div class="table-responsive">
                <% if (availableRooms.length > 0) { %> 
                    <table class="table table-striped text-center my-4">
                        <thead>
                            <tr class="table-dark">
                                <th>ID</th>
                                <th>Nom</th>
                                <th>Capacité</th>
                                <th>Emplacement</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% availableRooms.forEach(room => { %>
                                <tr>
                                    <td><%= room._id %></td>
                                    <td><%= room.name %></td>
                                    <td><%= room.capacity %></td>
                                    <td><%= room.location %></td>
                                    <td>
                                        <a href="/api/roomMeeting/<%= room._id %>" class="text-success"><i class="fas fa-edit fa-lg mx-1"></i></a>
                                        <a href="/api/roomMeeting/create" class="text-success"><i class="fas fa-plus-square mx-1"></i></a>
                                        <a href="/api/roomMeeting/delete/<%= room._id %>" class="text-danger"><i class="fas fa-trash fa-lg mx-1"></i></a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <h1 class="text-center text-secondary mt-5">Aucune salle de réunion disponible.</h1>
                <% } %>
            </div>
        </div>
    </div>
</div>
<%- include('layout/footer') %>
