<%- include('layout/header') %>
            <div class="container">
                <div class="row">
                    <div class="col-lg-6 mx-auto mt-4">
                        <div class="card shadow">
                            <div class="card-header bg-success">
                                <h5 class="text-light">Update User</h5>
                            </div>
                            <div class="card-body p-4">
                                <form action="/api/auth/update/<%=user._id%>" method="post" id="add-form" >
                                     
                                    <div class="mb-3">
                                        <label for="email">Email</label>
                                        <input type="email" value="<%=user.email%>" name="email" class="form-control form-control-lg" placeholder="Enter Email" required/>
                                    </div>
                                    <div class="mb-3">
                                        <label for="password">Mots De Passe </label>
                                        <input type="password" value="<%=user.password%>" name="password" class="form-control form-control-lg" placeholder="Enter password" required/>
                                    </div>
                                    <div class="mb-3">
                                        <input type="submit" name="submit" value="update" class="btn btn-success btn-lg" />
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
         
<%- include('layout/footer') %>