<%- include('layout/header') %>
<div class="container">
    <div class="row my-4">
        <div class="col-lg-12">
            <div class="table-responsive">
                <% if (bookings.length > 0) { %> 
                    <table class="table table-striped text-center my-4">
                        <thead>
                            <tr class="table-dark">
                                <th>ID</th>
                                <th>Utilisateur</th>
                                <th>Salle de Réunion</th>
                                <th>Date de début</th>
                                <th>Date de fin</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bookings.forEach(booking => { %>
                                <tr>
                                    <td><%= booking._id %></td>
                                    <td><%= booking.user %></td>
                                    <td><%= booking.room %></td>
                                    <td><%= booking.startTime %></td>
                                    <td><%= booking.endTime %></td>
                                    <td>
                                        <a href="/api/bookings/edit/<%= booking._id %>" class="text-success"><i class="fas fa-edit fa-lg mx-1"></i></a>
                                        <a href="/api/bookings/create" class="text-success"><i class="fas fa-plus-square mx-1"></i></a>
                                        <a href="/api/bookings/cancel/<%= booking._id %>" class="text-danger"><i class="fas fa-trash fa-lg mx-1"></i></a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <h1 class="text-center text-secondary mt-5">Aucune réservation disponible.</h1>
                <% } %>
            </div>
        </div>
    </div>
</div>
<%- include('layout/footer') %>
